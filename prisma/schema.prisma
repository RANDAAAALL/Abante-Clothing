generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model address {
  address_ID                                                   Int               @id @default(autoincrement())
  user_ID                                                      Int?
  address_type                                                 String?           @db.VarChar(255)
  recipient_first_name                                         String?           @db.VarChar(255)
  recipient_last_name                                          String?           @db.VarChar(255)
  company_name                                                 String?           @db.VarChar(255)
  address_name                                                 String?           @db.VarChar(255)
  apartment_name                                               String?           @db.VarChar(255)
  postal_code                                                  Int?
  city_name                                                    String?           @db.VarChar(255)
  region_name                                                  String?           @db.VarChar(255)
  phone_number                                                 Int?
  users                                                        users?            @relation(fields: [user_ID], references: [user_ID], onDelete: NoAction, onUpdate: NoAction, map: "address_ibfk_1")
  order_purchased_order_purchased_delivery_address_IDToaddress order_purchased[] @relation("order_purchased_delivery_address_IDToaddress")
  order_purchased_order_purchased_billing_address_IDToaddress  order_purchased[] @relation("order_purchased_billing_address_IDToaddress")

  @@index([user_ID], map: "user_ID")
}

model cart_items {
  cart_item_ID    Int            @id @default(autoincrement())
  user_ID         Int?
  product_item_ID Int?
  cart_item_image String?        @db.VarChar(255)
  cart_item_name  String?        @db.VarChar(50)
  cart_item_price Decimal?       @db.Decimal(10, 2)
  cart_item_size  String?        @db.VarChar(255)
  cart_item_color String?        @db.VarChar(255)
  cart_item_qty   Int?
  cart_item_total Decimal?       @db.Decimal(10, 2)
  cart_item_date  DateTime?      @db.DateTime(0)
  users           users?         @relation(fields: [user_ID], references: [user_ID], onDelete: NoAction, onUpdate: NoAction, map: "cart_items_ibfk_1")
  product_items   product_items? @relation(fields: [product_item_ID], references: [product_item_ID], onDelete: NoAction, onUpdate: NoAction, map: "cart_items_ibfk_2")

  @@index([product_item_ID], map: "product_item_ID")
  @@index([user_ID], map: "user_ID")
}

model deleted {
  deleted_ID         Int       @id
  user_ID            Int?
  deleted_item_ID    Int?
  deleted_item_table String?   @db.VarChar(50)
  deleted_date       DateTime? @db.DateTime(0)
  users              users?    @relation(fields: [user_ID], references: [user_ID], onDelete: NoAction, onUpdate: NoAction, map: "deleted_ibfk_1")

  @@index([user_ID], map: "user_ID")
}

model order_details {
  order_detail_ID    Int              @id @default(autoincrement())
  order_purchased_ID Int?
  product_item_ID    Int?
  order_detail_name  String?          @db.VarChar(255)
  order_detail_qty   Int?
  order_detail_price Decimal?         @db.Decimal(10, 2)
  order_detail_size  String?          @db.VarChar(50)
  order_purchased    order_purchased? @relation(fields: [order_purchased_ID], references: [order_purchased_ID], onDelete: NoAction, onUpdate: NoAction, map: "order_details_ibfk_1")
  product_items      product_items?   @relation(fields: [product_item_ID], references: [product_item_ID], onDelete: NoAction, onUpdate: NoAction, map: "order_details_ibfk_2")
  users_feedback     users_feedback[]

  @@index([order_purchased_ID], map: "order_purchased_ID")
  @@index([product_item_ID], map: "product_item_ID")
}

model order_purchased {
  order_purchased_ID                                   Int             @id @default(autoincrement())
  user_ID                                              Int?
  delivery_address_ID                                  Int?
  billing_address_ID                                   Int?
  payment_ID                                           Int?
  order_purchased_totalAmount                          Decimal?        @db.Decimal(10, 2)
  order_purchased_date                                 DateTime?       @db.DateTime(0)
  order_purchased_status                               String?         @db.VarChar(25)
  order_details                                        order_details[]
  users                                                users?          @relation(fields: [user_ID], references: [user_ID], onDelete: NoAction, onUpdate: NoAction, map: "order_purchased_ibfk_1")
  address_order_purchased_delivery_address_IDToaddress address?        @relation("order_purchased_delivery_address_IDToaddress", fields: [delivery_address_ID], references: [address_ID], onDelete: NoAction, onUpdate: NoAction, map: "order_purchased_ibfk_2")
  address_order_purchased_billing_address_IDToaddress  address?        @relation("order_purchased_billing_address_IDToaddress", fields: [billing_address_ID], references: [address_ID], onDelete: NoAction, onUpdate: NoAction, map: "order_purchased_ibfk_3")
  payments                                             payments?       @relation(fields: [payment_ID], references: [payment_ID], onDelete: NoAction, onUpdate: NoAction, map: "order_purchased_ibfk_4")

  @@index([billing_address_ID], map: "billing_address_ID")
  @@index([delivery_address_ID], map: "delivery_address_ID")
  @@index([payment_ID], map: "payment_ID")
  @@index([user_ID], map: "user_ID")
}

model payments {
  payment_ID      Int               @id
  user_ID         Int?
  payment_method  String?           @db.VarChar(255)
  payment_amount  Decimal?          @db.Decimal(10, 2)
  payment_date    DateTime?         @db.DateTime(0)
  order_purchased order_purchased[]
  users           users?            @relation(fields: [user_ID], references: [user_ID], onDelete: NoAction, onUpdate: NoAction, map: "payments_ibfk_1")

  @@index([user_ID], map: "user_ID")
}

model product_items {
  product_item_ID              Int             @id
  user_ID                      Int?
  product_item_name            String?         @db.VarChar(255)
  product_item_price           Decimal?        @db.Decimal(10, 2)
  product_item_image           String?         @db.VarChar(255)
  product_item_color           String?         @db.VarChar(255)
  product_item_size            String?         @db.VarChar(255)
  product_item_material        String?         @db.VarChar(255)
  product_item_construction    String?         @db.VarChar(255)
  product_item_design_features String?         @db.VarChar(255)
  product_item_stock           Int?
  product_item_displayDate     DateTime?       @db.DateTime(0)
  product_item_status          String?         @db.VarChar(255)
  product_item_back_image      String?         @db.VarChar(255)
  cart_items                   cart_items[]
  order_details                order_details[]
  users                        users?          @relation(fields: [user_ID], references: [user_ID], onDelete: NoAction, onUpdate: NoAction, map: "product_items_ibfk_1")

  @@index([user_ID], map: "user_ID")
}

model returns {
  return_ID         Int       @id
  user_ID           Int?
  return_item_ID    Int?
  return_status     String?   @db.VarChar(50)
  return_type_issue String?   @db.VarChar(50)
  return_date       DateTime? @db.DateTime(0)
  users             users?    @relation(fields: [user_ID], references: [user_ID], onDelete: NoAction, onUpdate: NoAction, map: "returns_ibfk_1")

  @@index([user_ID], map: "user_ID")
}

model users {
  user_ID         Int               @id @default(autoincrement())
  user_image      String?           @db.VarChar(255)
  username        String?           @db.VarChar(255)
  email           String?           @unique @db.VarChar(255)
  password        String?           @db.VarChar(255)
  role            String?           @db.VarChar(50)
  createdAt       DateTime          @default(now()) @db.DateTime(0)
  address         address[]
  cart_items      cart_items[]
  deleted         deleted[]
  order_purchased order_purchased[]
  payments        payments[]
  product_items   product_items[]
  returns         returns[]
  users_feedback  users_feedback[]
}

model users_feedback {
  feedback_ID      Int            @id
  user_ID          Int?
  order_detail_ID  Int?
  feedback_comment String?        @db.VarChar(255)
  feedback_rating  Int?
  feedback_date    DateTime?      @db.DateTime(0)
  users            users?         @relation(fields: [user_ID], references: [user_ID], onDelete: NoAction, onUpdate: NoAction, map: "users_feedback_ibfk_1")
  order_details    order_details? @relation(fields: [order_detail_ID], references: [order_detail_ID], onDelete: NoAction, onUpdate: NoAction, map: "users_feedback_ibfk_2")

  @@index([order_detail_ID], map: "order_detail_ID")
  @@index([user_ID], map: "user_ID")
}
